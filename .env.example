# Sentinel .env example | .env 示例
# EN: Copy this file to `.env` and fill in the key for the provider you use.
#     Only ONE is needed. `.env` is git-ignored — never commit real keys.
# ZH: 把本文件复制成 `.env`，填上你所用 Provider 的 key。只需填一个。
#     `.env` 已被 git 忽略——绝不要提交真实 key。

# ModelScope 魔搭（国内，有免费额度）
MODELSCOPE_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# Claude (Anthropic)
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=
# AIHubmix
AIHUBMIX_API_KEY=

# EN: optional — override the model id for any provider.
# ZH: 可选 —— 覆盖任意 Provider 的模型 id。
# LLM_MODEL_ID=
